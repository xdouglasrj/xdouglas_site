// =============================================================
// xDouglas — Schema Prisma
// =============================================================
// Fase 1 (nova arquitetura): Genre, Playlist, PlaylistTrack,
// ForumSector, Notification, Role.MODERATOR, campos de
// privacidade no User, featureFlags no AppSettings.
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum Role {
  GUEST
  MEMBER
  ARTIST
  ARTIST_SUPPORTER
  MODERATOR
  ADMIN
}

// Plano de armazenamento do usuário — define a cota de espaço usada nos
// uploads de música (ver lib/settings/plan-quotas.ts pelos valores em MB)
enum UserPlan {
  FREE
  PAID
}

enum DownloadStatus {
  INICIADO
  CONCLUIDO
  EXPIRADO
}

enum WaitlistTipoUsuario {
  DJ
  PRODUTOR
  ARTISTA
  MUSICO
  OUVINTE
  OUTRO
}

// =============================================================
// GAMIFICAÇÃO — enums
// =============================================================

// Toda ação que gera (ou remove) pontos passa por aqui — histórico
// completo em PointsHistory, nunca alteração direta de saldo.
enum PointActionType {
  USER_REGISTERED
  PROFILE_COMPLETED
  AVATAR_ADDED
  FIRST_LOGIN
  DAILY_LOGIN
  DAILY_LOGIN_STREAK_BONUS
  TRACK_LIKED
  COMMENT_CREATED
  TRACK_SHARED
  TRACK_PUBLISHED
  TRACK_PLAYED
  PLAYLIST_CREATED
  FRIEND_INVITE_COMPLETED
  TRACK_MILESTONE_1000
  STORE_REDEMPTION
  INVITE_ABUSE_PENALTY
  ADMIN_GIFT
  ADMIN_ADJUSTMENT
}

// Pra quem o item da loja está disponível — Artista (role ARTIST) ou
// Ouvinte (demais roles não-admin), ou os dois.
enum StoreAudience {
  ARTIST
  LISTENER
  BOTH
}

enum StoreItemKey {
  PRIORITY_INVITE
  PIN_TRACK_COMMENT
  FEATURE_TRACK
  EXTRA_STORAGE
  MAPPING_ACCESS
  APP_PREMIUM
  PIN_FEED_POST
}

// Ciclo de vida de uma compra na loja — itens "de uso" (fixar
// comentário/destaque) passam por AWAITING_USE -> ACTIVE -> USED/EXPIRED;
// itens "de efeito imediato" (armazenamento, convite) vão direto pra USED.
enum StorePurchaseStatus {
  AWAITING_USE
  ACTIVE
  USED
  EXPIRED
  REFUNDED
}

enum PaymentOrderStatus {
  PENDING
  PAID
  FAILED
}

enum AuditAction {
  LOGIN
  LOGOUT
  TRACK_CREATE
  TRACK_UPDATE
  TRACK_DELETE
  ARTIST_CREATE
  ARTIST_UPDATE
  ARTIST_DELETE
  ADMIN_ACCESS
  SUSPICIOUS_DOWNLOAD_FLAGGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PERMISSIONS_UPDATE
}

enum EventType {
  PAGE_VIEW
  MUSIC_VIEW
  DOWNLOAD_START
  DOWNLOAD_COMPLETE
  DOWNLOAD_FAILED
  WAITLIST_JOIN
  CONSENT_GIVEN
  CONSENT_REVOKED
  PLAY_START
  PLAY_30S
  PLAY_COMPLETE
}

enum ReportTargetType {
  POST
  COMMENT
  FORUM_THREAD
  FORUM_REPLY
  TRACK
  USER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum SupportTicketStatus {
  PENDING
  RESOLVED
}

enum SupportCategory {
  BUG
  SUGESTAO
  DUVIDA
  OUTRO
}

enum SupportAttachmentType {
  IMAGE
  VIDEO
}

// =============================================================
// USERS — base de todos os papéis
// =============================================================

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  // Identificador de LOGIN — privado, nunca exibido publicamente nem usado
  // em rotas/links de perfil (ver "handle" abaixo para o @ público)
  username               String?   @unique @map("username")
  password               String
  name                   String?
  // @ público da comunidade — usado em /perfil/<handle> e nas menções no
  // fórum/feed. Separado do username de login por segurança.
  handle                 String?   @unique @map("handle")
  role                   Role      @default(GUEST)
  // Permissões granulares de moderador (só usadas quando role == MODERATOR)
  permissions            String[]  @default([]) @map("permissions")
  // Cota de armazenamento de upload — ver lib/settings/plan-quotas.ts
  plan                   UserPlan  @default(FREE)
  active                 Boolean   @default(true)
  inviteCode             String?   @map("invite_code")
  phone                  String?
  artisticName           String?   @map("artistic_name")
  newsletterOptIn        Boolean   @default(false) @map("newsletter_opt_in")
  lastLoginAt            DateTime? @map("last_login_at")
  blocked                Boolean   @default(false)
  blockedAt              DateTime? @map("blocked_at")
  photoKey               String?   @map("photo_key")
  photoUrl               String?   @map("photo_url")

  // Privacidade — campos originais
  showEmail              Boolean   @default(false) @map("show_email")
  showPhone              Boolean   @default(false) @map("show_phone")
  showName               Boolean   @default(true)  @map("show_name")

  // Privacidade — campos novos (Fase 1)
  showMusicasNoPerfil      Boolean @default(true)  @map("show_musicas_perfil")
  showEspacoUploadNoPerfil Boolean @default(true)  @map("show_upload_space_perfil")
  showContatosNoPerfil     Boolean @default(false) @map("show_contatos_perfil")
  allowComentariosNaMusica Boolean @default(true)  @map("allow_comentarios_musica")
  showComentariosVisiveis  Boolean @default(true)  @map("show_comentarios_visiveis")

  mappingEnabled         Boolean   @default(false) @map("mapping_enabled")
  resetPasswordTokenHash String?   @unique @map("reset_password_token_hash")
  resetPasswordExpiresAt DateTime? @map("reset_password_expires_at")
  resetPasswordUsedAt    DateTime? @map("reset_password_used_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  // Gamificação
  totalXp               Int       @default(0) @map("total_xp")
  level                 Int       @default(1)
  loginStreak           Int       @default(0) @map("login_streak")
  lastDailyLoginAt      DateTime? @map("last_daily_login_at")
  priorityInviteCredits Int       @default(0) @map("priority_invite_credits")
  bonusStorageMb        Int       @default(0) @map("bonus_storage_mb")
  mappingExpiresAt      DateTime? @map("mapping_expires_at")
  appPremiumExpiresAt   DateTime? @map("app_premium_expires_at")
  inviteAbuseLevel      Int       @default(0) @map("invite_abuse_level")
  inviteBlockedUntil    DateTime? @map("invite_blocked_until")

  pointsHistory           PointsHistory[]
  storePurchases          StorePurchase[]
  paymentOrders           PaymentOrder[]
  referredWaitlistEntries Waitlist[]      @relation("WaitlistReferrals")

  adminSessions   AdminSession[]
  auditLogs       AuditLog[]
  artist          Artist?
  submittedTracks Track[]        @relation("TrackSubmittedBy")

  // Social
  following      Follow[]        @relation("Follower")
  followers      Follow[]        @relation("Following")
  posts          Post[]
  likes          Like[]
  trackLikes     TrackLike[]
  comments       Comment[]
  trackComments  TrackComment[]
  forumThreads   ForumThread[]
  forumReplies   ForumReply[]
  reportsMade    Report[]        @relation("ReportsMade")
  supportTickets SupportTicket[]

  // Novos (Fase 1)
  playlists      Playlist[]
  notifications  Notification[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// =============================================================
// SOCIAL — seguir
// =============================================================

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  followingId String   @map("following_id")
  following   User     @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// =============================================================
// SOCIAL — feed (posts, curtidas, comentários)
// =============================================================

model Post {
  id              String    @id @default(uuid())
  authorId        String    @map("author_id")
  author          User      @relation(fields: [authorId], references: [id])
  content         String
  createdAt       DateTime  @default(now()) @map("created_at")
  pinned          Boolean   @default(false)
  pinnedAt        DateTime? @map("pinned_at")
  pinnedExpiresAt DateTime? @map("pinned_expires_at")

  likes    Like[]
  comments Comment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([pinned])
  @@map("posts")
}

model Like {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id])
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId])
  @@index([postId])
  @@map("likes")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String    @map("post_id")
  post      Post      @relation(fields: [postId], references: [id])
  authorId  String    @map("author_id")
  author    User      @relation(fields: [authorId], references: [id])
  content   String
  pinned    Boolean   @default(false)
  pinnedAt  DateTime? @map("pinned_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([postId])
  @@index([pinned])
  @@map("comments")
}

// =============================================================
// FÓRUM — setores, tópicos e respostas
// =============================================================

model ForumSector {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  description   String?
  order         Int      @default(0)
  onlyAdminPost Boolean  @default(false) @map("only_admin_post")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  threads ForumThread[]

  @@index([active])
  @@index([order])
  @@map("forum_sectors")
}

model ForumThread {
  id        String   @id @default(uuid())
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  title     String
  body      String
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Setor ao qual o tópico pertence (nullable para compatibilidade com
  // tópicos criados antes da setorização)
  sectorId  String?      @map("sector_id")
  sector    ForumSector? @relation(fields: [sectorId], references: [id])

  replies ForumReply[]

  @@index([authorId])
  @@index([createdAt])
  @@index([sectorId])
  @@map("forum_threads")
}

model ForumReply {
  id        String      @id @default(uuid())
  threadId  String      @map("thread_id")
  thread    ForumThread @relation(fields: [threadId], references: [id])
  authorId  String      @map("author_id")
  author    User        @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([threadId])
  @@map("forum_replies")
}

// =============================================================
// DENÚNCIAS — moderação de conteúdo
// =============================================================

model Report {
  id         String           @id @default(uuid())
  reporterId String           @map("reporter_id")
  reporter   User             @relation("ReportsMade", fields: [reporterId], references: [id])
  targetType ReportTargetType @map("target_type")
  targetId   String           @map("target_id")
  reason     String
  status     ReportStatus     @default(PENDING)
  resolvedAt DateTime?        @map("resolved_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([status])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("reports")
}

// =============================================================
// SUPORTE — chamados abertos pelos membros
// =============================================================

model SupportTicket {
  id             String                 @id @default(uuid())
  userId         String                 @map("user_id")
  user           User                   @relation(fields: [userId], references: [id])
  category       SupportCategory        @default(OUTRO)
  message        String
  attachmentKey  String?                @map("attachment_key")
  attachmentUrl  String?                @map("attachment_url")
  attachmentType SupportAttachmentType? @map("attachment_type")
  status         SupportTicketStatus    @default(PENDING)
  resolvedAt     DateTime?              @map("resolved_at")
  createdAt      DateTime               @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

// =============================================================
// ARTISTS
// =============================================================

model Artist {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  bio       String?
  photoKey  String?  @map("photo_key")
  photoUrl  String?  @map("photo_url")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  schedulingToken String? @unique @map("scheduling_token")

  tracks Track[]

  @@index([slug])
  @@index([active])
  @@map("artists")
}

// =============================================================
// GÊNEROS MUSICAIS — hierárquico (categoria-mãe + subgêneros)
// =============================================================

model Genre {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  parentId  String?  @map("parent_id")
  parent    Genre?   @relation("GenreHierarchy", fields: [parentId], references: [id])
  children  Genre[]  @relation("GenreHierarchy")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  tracks Track[]

  @@index([parentId])
  @@index([active])
  @@index([order])
  @@map("genres")
}

// =============================================================
// TRACKS (músicas)
// =============================================================

model Track {
  id          String  @id @default(uuid())
  slug        String  @unique
  title       String
  description String?
  // genre (String) mantido durante a transição — será removido após migração
  // de dados existentes para genreId
  genre       String?
  // genreId é a FK nova para o catálogo hierárquico de gêneros
  genreId     String? @map("genre_id")
  genreRef    Genre?  @relation(fields: [genreId], references: [id])
  bpm         Int?
  key         String?

  artistId     String  @map("artist_id")
  artist       Artist  @relation(fields: [artistId], references: [id])
  producerName String? @map("producer_name")

  submittedById String? @map("submitted_by_id")
  submittedBy   User?   @relation("TrackSubmittedBy", fields: [submittedById], references: [id])

  audioKey       String  @map("audio_key")
  audioFormat    String  @map("audio_format")
  audioSizeBytes BigInt? @map("audio_size_bytes")
  coverKey       String? @map("cover_key")
  coverUrl       String? @map("cover_url")

  downloadAudioKey        String? @map("download_audio_key")
  downloadAudioVinhetaKey String? @map("download_audio_vinheta_key")

  published     Boolean   @default(false)
  publishedAt   DateTime? @map("published_at")
  downloadCount Int       @default(0) @map("download_count")
  pinned        Boolean   @default(false)
  pinnedAt      DateTime? @map("pinned_at")
  featuredUntil DateTime? @map("featured_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  scheduledAt   DateTime? @map("scheduled_at")

  downloads     Download[]
  likes         TrackLike[]
  comments      TrackComment[]
  playlistTracks PlaylistTrack[]

  @@index([slug])
  @@index([artistId])
  @@index([published])
  @@index([genre])
  @@index([genreId])
  @@index([submittedById])
  @@index([pinned])
  @@index([scheduledAt])
  @@map("tracks")
}

model TrackComment {
  id              String    @id @default(uuid())
  trackId         String    @map("track_id")
  track           Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  authorId        String    @map("author_id")
  author          User      @relation(fields: [authorId], references: [id])
  content         String
  editedAt        DateTime? @map("edited_at")
  pinned          Boolean   @default(false)
  pinnedAt        DateTime? @map("pinned_at")
  pinnedExpiresAt DateTime? @map("pinned_expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([trackId])
  @@index([pinned])
  @@map("track_comments")
}

model TrackLike {
  id        String   @id @default(uuid())
  trackId   String   @map("track_id")
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([trackId, userId])
  @@index([trackId])
  @@index([userId])
  @@map("track_likes")
}

// =============================================================
// PLAYLISTS
// =============================================================

model Playlist {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  coverKey    String?  @map("cover_key")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tracks PlaylistTrack[]

  @@index([userId])
  @@map("playlists")
}

model PlaylistTrack {
  id         String   @id @default(uuid())
  playlistId String   @map("playlist_id")
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  trackId    String   @map("track_id")
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  position   Int
  addedAt    DateTime @default(now()) @map("added_at")

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
  @@map("playlist_tracks")
}

// =============================================================
// NOTIFICAÇÕES
// =============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  // tipo: "novo_seguidor" | "curtida" | "comentario" | "resposta_forum" |
  //        "musica_publicada" | "presente_admin"
  type      String
  payload   Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// =============================================================
// DOWNLOADS
// =============================================================

model Download {
  id      String @id @default(uuid())
  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?

  device  String?
  browser String?
  os      String?

  status           DownloadStatus @default(INICIADO)
  signedUrlExpiry  DateTime?      @map("signed_url_expiry")
  downloadSuspeito Boolean        @default(false) @map("download_suspeito")
  createdAt        DateTime       @default(now()) @map("created_at")
  completedAt      DateTime?      @map("completed_at")

  @@index([trackId])
  @@index([downloadSuspeito])
  @@index([createdAt])
  @@index([status])
  @@index([trackId, downloadSuspeito, createdAt])
  @@map("downloads")
}

// =============================================================
// ANALYTICS — camada 1 (dados técnicos, retenção 90 dias)
// =============================================================

model AnalyticsRawEvent {
  id        String    @id @default(uuid())
  eventType EventType @map("event_type")

  ipHash    String? @map("ip_hash")
  hashKeyId String? @map("hash_key_id")

  userAgent String? @map("user_agent")
  device    String?
  browser   String?
  os        String?
  referer   String?

  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?

  trackId   String? @map("track_id")
  sessionId String? @map("session_id")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([eventType])
  @@index([expiresAt])
  @@index([ipHash])
  @@index([createdAt])
  @@map("analytics_raw_events")
}

// =============================================================
// ANALYTICS — camada 2 (dados processados, sem IP, permanentes)
// =============================================================

model AnalyticsEvent {
  id        String    @id @default(uuid())
  eventType EventType @map("event_type")

  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?

  device  String?
  browser String?
  os      String?

  trackId   String? @map("track_id")
  sessionId String? @map("session_id")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([trackId])
  @@index([createdAt])
  @@index([country])
  @@index([eventType, createdAt])
  @@map("analytics_events")
}

// =============================================================
// ANALYTICS — chaves de hash rotativas (LGPD)
// =============================================================

model AnalyticsHashKey {
  id            String   @id @default(uuid())
  saltEncrypted String   @map("salt_encrypted")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([active])
  @@index([periodEnd])
  @@map("analytics_hash_keys")
}

// =============================================================
// ADMIN SESSIONS
// =============================================================

model AdminSession {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  accessTokenHash  String @unique @map("access_token_hash")
  refreshTokenHash String @unique @map("refresh_token_hash")

  ipHash    String? @map("ip_hash")
  userAgent String? @map("user_agent")
  device    String?

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([accessTokenHash])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("admin_sessions")
}

// =============================================================
// AUDIT LOGS — rastreabilidade de ações admin
// =============================================================

model AuditLog {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  user       User        @relation(fields: [userId], references: [id])
  action     AuditAction
  entityId   String?     @map("entity_id")
  entityType String?     @map("entity_type")
  metadata   Json?
  ipHash     String?     @map("ip_hash")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// WAITLIST
// =============================================================

model Waitlist {
  id               String              @id @default(uuid())
  email            String              @unique
  name             String?
  phone            String?
  tipoUsuario      WaitlistTipoUsuario @map("tipo_usuario")
  message          String?
  consentedAt      DateTime            @map("consented_at")
  invitedAt        DateTime?           @map("invited_at")
  inviteCode       String?             @unique @map("invite_code")
  usedAt           DateTime?           @map("used_at")
  referredByUserId String?             @map("referred_by_user_id")
  referredByUser   User?               @relation("WaitlistReferrals", fields: [referredByUserId], references: [id])
  priority         Boolean             @default(false)
  createdAt        DateTime            @default(now()) @map("created_at")

  @@index([tipoUsuario])
  @@index([invitedAt])
  @@index([referredByUserId])
  @@index([priority])
  @@map("waitlist")
}

// =============================================================
// CONSENT EVENTS — rastreabilidade LGPD
// =============================================================

model ConsentEvent {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  eventType   String   @map("event_type")
  consentType String   @map("consent_type")
  ipHash      String?  @map("ip_hash")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("consent_events")
}

// =============================================================
// GAMIFICAÇÃO — pontos, loja, mercado de preço dinâmico, promoções
// =============================================================

model PointsHistory {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id])
  action      PointActionType
  points      Int
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action])
  @@map("points_history")
}

model StoreItem {
  id       String        @id @default(uuid())
  key      StoreItemKey  @unique
  label    String
  audience StoreAudience
  price    Int

  maxConcurrent       Int? @map("max_concurrent")
  saleWindowHours     Int? @map("sale_window_hours")
  saleWindowLimit     Int? @map("sale_window_limit")
  durationHours       Int? @map("duration_hours")
  maxPurchasesPerUser Int? @map("max_purchases_per_user")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchases        StorePurchase[]
  thresholdEvents  StoreThresholdEvent[]
  priceAdjustments StorePriceAdjustment[]

  @@map("store_items")
}

model StorePurchase {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  user        User                @relation(fields: [userId], references: [id])
  storeItemId String              @map("store_item_id")
  storeItem   StoreItem           @relation(fields: [storeItemId], references: [id])
  pricePaid   Int                 @map("price_paid")
  status      StorePurchaseStatus @default(AWAITING_USE)

  targetType String? @map("target_type")
  targetId   String? @map("target_id")

  isGift          Boolean @default(false) @map("is_gift")
  giftedByAdminId String? @map("gifted_by_admin_id")

  purchasedAt DateTime  @default(now()) @map("purchased_at")
  usableUntil DateTime? @map("usable_until")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime? @map("expires_at")

  @@index([userId])
  @@index([storeItemId, purchasedAt])
  @@index([status])
  @@map("store_purchases")
}

model PaymentOrder {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  user            User               @relation(fields: [userId], references: [id])
  orderNsu        String             @unique @map("order_nsu")
  product         String
  amountCents     Int                @map("amount_cents")
  status          PaymentOrderStatus @default(PENDING)
  checkoutUrl     String?            @map("checkout_url")
  transactionNsu  String?            @map("transaction_nsu")
  invoiceSlug     String?            @map("invoice_slug")
  captureMethod   String?            @map("capture_method")
  paidAmountCents Int?               @map("paid_amount_cents")

  createdAt DateTime  @default(now()) @map("created_at")
  paidAt    DateTime? @map("paid_at")

  @@index([userId])
  @@index([status])
  @@map("payment_orders")
}

model StoreThresholdEvent {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  storeItemId  String    @map("store_item_id")
  storeItem    StoreItem @relation(fields: [storeItemId], references: [id])
  priceAtReach Int       @map("price_at_reach")
  reachedAt    DateTime  @default(now()) @map("reached_at")

  @@unique([userId, storeItemId, priceAtReach])
  @@index([storeItemId, reachedAt])
  @@map("store_threshold_events")
}

model StorePriceAdjustment {
  id               String    @id @default(uuid())
  storeItemId      String    @map("store_item_id")
  storeItem        StoreItem @relation(fields: [storeItemId], references: [id])
  oldPrice         Int       @map("old_price")
  newPrice         Int       @map("new_price")
  triggeredByCount Int       @map("triggered_by_count")
  windowStart      DateTime  @map("window_start")
  windowEnd        DateTime  @map("window_end")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([storeItemId, createdAt])
  @@map("store_price_adjustments")
}

model PointsPromotion {
  id         String    @id @default(uuid())
  label      String
  multiplier Float     @default(2.0)
  startAt    DateTime? @map("start_at")
  endAt      DateTime? @map("end_at")
  weekday    Int?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("points_promotions")
}

// =============================================================
// APP SETTINGS — configurações globais (linha única "singleton")
// =============================================================

model AppSettings {
  id                  String  @id @default("singleton")
  autoAcceptEnabled   Boolean @default(false) @map("auto_accept_enabled")
  autoAcceptRemaining Int     @default(0) @map("auto_accept_remaining")

  musicMaxSizeMb   Int     @default(10) @map("music_max_size_mb")
  podcastMaxSizeMb Int     @default(100) @map("podcast_max_size_mb")
  podcastEnabled   Boolean @default(false) @map("podcast_enabled")

  contentExpirationHours Int @default(24) @map("content_expiration_hours")

  vinhetaKey         String? @map("vinheta_key")
  vinhetaDownloadKey String? @map("vinheta_download_key")

  inviteAbuseBlockDays Int @default(30) @map("invite_abuse_block_days")

  storeDynamicPriceThresholdCount  Int @default(3)   @map("store_dynamic_price_threshold_count")
  storeDynamicPriceWindowHours     Int @default(720) @map("store_dynamic_price_window_hours")
  storeDynamicPriceIncreasePercent Int @default(20)  @map("store_dynamic_price_increase_percent")

  // Feature flags — cada chave é um boolean. Default "{}" = todas ligadas
  // pelo seed. Lidas em runtime via lib/settings/feature-flags.ts (cache 30s).
  featureFlags Json @default("{}") @map("feature_flags")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
