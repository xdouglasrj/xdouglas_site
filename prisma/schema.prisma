// =============================================================
// xDouglas — Schema Prisma Fase 1
// =============================================================
// Tabelas ativas na Fase 1:
//   users, artists, tracks, downloads
//   analytics_raw_events, analytics_events, analytics_hash_keys
//   admin_sessions, audit_logs
//   waitlist, consent_events
//
// Gamificação (pontos, níveis, loja, convite por indicação) — ver seção
// "GAMIFICAÇÃO" mais abaixo: points_history, store_items, store_purchases,
// store_threshold_events, store_price_adjustments, points_promotions
//
// Reservadas para Fase 2+ (não criadas agora):
//   memberships, plans, feature_permissions
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum Role {
  GUEST
  MEMBER
  ARTIST
  ARTIST_SUPPORTER
  ADMIN
}

// Plano de armazenamento do usuário — define a cota de espaço usada nos
// uploads de música (ver lib/settings/plan-quotas.ts pelos valores em MB)
enum UserPlan {
  FREE
  PAID
}

enum DownloadStatus {
  INICIADO
  CONCLUIDO
  EXPIRADO
}

enum WaitlistTipoUsuario {
  DJ
  PRODUTOR
  ARTISTA
  MUSICO
  OUVINTE
  OUTRO
}

// =============================================================
// GAMIFICAÇÃO — enums
// =============================================================

// Toda ação que gera (ou remove) pontos passa por aqui — histórico
// completo em PointsHistory, nunca alteração direta de saldo.
enum PointActionType {
  USER_REGISTERED
  PROFILE_COMPLETED
  AVATAR_ADDED
  FIRST_LOGIN
  DAILY_LOGIN
  DAILY_LOGIN_STREAK_BONUS
  TRACK_LIKED
  COMMENT_CREATED
  TRACK_SHARED
  TRACK_PUBLISHED
  TRACK_PLAYED
  PLAYLIST_CREATED
  FRIEND_INVITE_COMPLETED
  TRACK_MILESTONE_1000
  STORE_REDEMPTION
  INVITE_ABUSE_PENALTY
  ADMIN_GIFT
  ADMIN_ADJUSTMENT
}

// Pra quem o item da loja está disponível — Artista (role ARTIST) ou
// Ouvinte (demais roles não-admin), ou os dois.
enum StoreAudience {
  ARTIST
  LISTENER
  BOTH
}

enum StoreItemKey {
  PRIORITY_INVITE
  PIN_TRACK_COMMENT
  FEATURE_TRACK
  EXTRA_STORAGE
  MAPPING_ACCESS
  APP_PREMIUM
  PIN_FEED_POST
}

// Ciclo de vida de uma compra na loja — itens "de uso" (fixar
// comentário/destaque) passam por AWAITING_USE -> ACTIVE -> USED/EXPIRED;
// itens "de efeito imediato" (armazenamento, convite) vão direto pra USED.
enum StorePurchaseStatus {
  AWAITING_USE
  ACTIVE
  USED
  EXPIRED
  REFUNDED
}

enum AuditAction {
  LOGIN
  LOGOUT
  TRACK_CREATE
  TRACK_UPDATE
  TRACK_DELETE
  ARTIST_CREATE
  ARTIST_UPDATE
  ARTIST_DELETE
  ADMIN_ACCESS
  SUSPICIOUS_DOWNLOAD_FLAGGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}

enum EventType {
  PAGE_VIEW
  MUSIC_VIEW
  DOWNLOAD_START
  DOWNLOAD_COMPLETE
  DOWNLOAD_FAILED
  WAITLIST_JOIN
  CONSENT_GIVEN
  CONSENT_REVOKED
  PLAY_START
  PLAY_30S
  PLAY_COMPLETE
}

enum ReportTargetType {
  POST
  COMMENT
  FORUM_THREAD
  FORUM_REPLY
  TRACK
  USER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum SupportTicketStatus {
  PENDING
  RESOLVED
}

enum SupportCategory {
  BUG
  SUGESTAO
  DUVIDA
  OUTRO
}

enum SupportAttachmentType {
  IMAGE
  VIDEO
}

// =============================================================
// USERS — base de todos os papéis (Fase 1 usa apenas ADMIN)
// =============================================================

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  // Identificador de LOGIN — privado, nunca exibido publicamente nem usado
  // em rotas/links de perfil (ver "handle" abaixo para o @ público)
  username               String?   @unique @map("username")
  password               String // bcrypt hash
  name                   String?
  // @ público da comunidade — usado em /perfil/<handle> e nas menções no
  // fórum/feed. Gerado a partir do nome no cadastro; o usuário pode trocar
  // depois em "Editar perfil". Separado do username de login por segurança:
  // o username não deve ser descobrível publicamente (evita facilitar
  // ataques de força bruta no login a partir do perfil público).
  handle                 String?   @unique @map("handle")
  role                   Role      @default(GUEST)
  // Cota de armazenamento de upload — ver lib/settings/plan-quotas.ts
  plan                   UserPlan  @default(FREE)
  active                 Boolean   @default(true)
  // Código de convite informado no cadastro de músico/produtor — validado manualmente por agora
  inviteCode             String?   @map("invite_code")
  phone                  String?
  // Nome artístico — preenchido no cadastro para quem não é Ouvinte
  artisticName           String?   @map("artistic_name")
  newsletterOptIn        Boolean   @default(false) @map("newsletter_opt_in")
  lastLoginAt            DateTime? @map("last_login_at")
  // Bloqueado pelo admin — impede novo cadastro com mesmo email/usuário/whatsapp
  blocked                Boolean   @default(false)
  blockedAt              DateTime? @map("blocked_at")
  // Foto de perfil — chave R2 + URL pública CDN
  photoKey               String?   @map("photo_key")
  photoUrl               String?   @map("photo_url")
  // Privacidade — o próprio usuário decide se email/telefone aparecem
  // para outros membros. O admin sempre vê todos os dados, independente
  // dessas flags.
  showEmail              Boolean   @default(false) @map("show_email")
  showPhone              Boolean   @default(false) @map("show_phone")
  // Visibilidade do nome real — só se aplica a artistas (ouvintes sempre exibem o nome)
  showName               Boolean   @default(true) @map("show_name")
  // Acesso à dashboard de estatísticas por faixa (plays, geo, device) em
  // /minhas-musicas — liberado manualmente pelo admin por usuário, será a
  // base de um plano pago futuro
  mappingEnabled         Boolean   @default(false) @map("mapping_enabled")
  // Redefinição de senha — apenas o hash do token é armazenado, nunca o token original
  resetPasswordTokenHash String?   @unique @map("reset_password_token_hash")
  resetPasswordExpiresAt DateTime? @map("reset_password_expires_at")
  // Marca quando o token foi efetivamente usado para trocar a senha —
  // permite distinguir "link já usado" de "link inválido/expirado"
  resetPasswordUsedAt    DateTime? @map("reset_password_used_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  // ---------------------------------------------------------------
  // Gamificação — XP é cumulativo e nunca decresce (nível é derivado
  // dele); saldo gastável na loja é calculado em runtime a partir do
  // PointsHistory, não fica num campo separado, pra não dessincronizar.
  // ---------------------------------------------------------------
  totalXp               Int       @default(0) @map("total_xp")
  level                 Int       @default(1)
  loginStreak           Int       @default(0) @map("login_streak")
  lastDailyLoginAt      DateTime? @map("last_daily_login_at")
  // Créditos comprados na loja pra priorizar uma indicação na fila do
  // admin — nunca pula o aceite manual, só reordena (ver Waitlist.priority)
  priorityInviteCredits Int       @default(0) @map("priority_invite_credits")
  // Soma ao PLAN_QUOTA_MB do plano — comprado em blocos de 200MB,
  // máx. 5 compras (teto de +1GB) controlado no StoreItem
  bonusStorageMb        Int       @default(0) @map("bonus_storage_mb")
  // Mapeamento (dashboard de stats) comprado por pontos — temporário,
  // diferente de `mappingEnabled` que é a liberação manual/permanente do
  // admin. Acesso efetivo = mappingEnabled OU mappingExpiresAt no futuro.
  mappingExpiresAt      DateTime? @map("mapping_expires_at")
  // Conta premium no app de música (ainda não lançado) — disponível pras
  // duas lojas (artista e ouvinte), benefícios mantidos em aberto de propósito
  appPremiumExpiresAt   DateTime? @map("app_premium_expires_at")
  // Penalidade por abuso de indicação de convite — escala editável em
  // AppSettings (ver inviteAbuseBlockDays); 0 = sem penalidade, 1 =
  // advertência, 2 = bloqueado de convidar, 3 = conta suspensa (usa o
  // `blocked` já existente acima)
  inviteAbuseLevel      Int       @default(0) @map("invite_abuse_level")
  inviteBlockedUntil    DateTime? @map("invite_blocked_until")

  pointsHistory           PointsHistory[]
  storePurchases          StorePurchase[]
  referredWaitlistEntries Waitlist[]      @relation("WaitlistReferrals")

  adminSessions   AdminSession[]
  auditLogs       AuditLog[]
  artist          Artist?
  submittedTracks Track[]        @relation("TrackSubmittedBy")

  // Social — seguir, feed, fórum, denúncias
  following      Follow[]        @relation("Follower")
  followers      Follow[]        @relation("Following")
  posts          Post[]
  likes          Like[]
  trackLikes     TrackLike[]
  comments       Comment[]
  trackComments  TrackComment[]
  forumThreads   ForumThread[]
  forumReplies   ForumReply[]
  reportsMade    Report[]        @relation("ReportsMade")
  supportTickets SupportTicket[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// =============================================================
// SOCIAL — seguir
// =============================================================

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  followingId String   @map("following_id")
  following   User     @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// =============================================================
// SOCIAL — feed (posts, curtidas, comentários)
// =============================================================

model Post {
  id              String    @id @default(uuid())
  authorId        String    @map("author_id")
  author          User      @relation(fields: [authorId], references: [id])
  content         String
  createdAt       DateTime  @default(now()) @map("created_at")
  // Fixado pelo admin — enquanto true, aparece sempre no topo do feed,
  // por tempo indeterminado, até o admin desativar o fixo
  pinned          Boolean   @default(false)
  pinnedAt        DateTime? @map("pinned_at")
  // Preenchido quando o fixo vem da loja (item PIN_FEED_POST, comprado
  // pelo próprio ouvinte) — nulo = fixado pelo admin, sem expiração;
  // valor = expira 24h após o uso, sem reembolso de pontos
  pinnedExpiresAt DateTime? @map("pinned_expires_at")

  likes    Like[]
  comments Comment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([pinned])
  @@map("posts")
}

model Like {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id])
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId])
  @@index([postId])
  @@map("likes")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String    @map("post_id")
  post      Post      @relation(fields: [postId], references: [id])
  authorId  String    @map("author_id")
  author    User      @relation(fields: [authorId], references: [id])
  content   String
  // Fixado pelo admin — enquanto true, ignora a janela de expiração (some
  // do soft-hide e do cron de limpeza) e aparece sempre no topo dos
  // comentários do post
  pinned    Boolean   @default(false)
  pinnedAt  DateTime? @map("pinned_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([postId])
  @@index([pinned])
  @@map("comments")
}

// =============================================================
// FÓRUM — tópicos e respostas
// =============================================================

model ForumThread {
  id        String   @id @default(uuid())
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  title     String
  body      String
  // Threads oficiais (regras de pontos; regras/punições de convite),
  // postadas pelo admin — ficam fixadas no topo do fórum
  pinned    Boolean  @default(false)
  // Bloqueado pelo admin — enquanto true, ninguém consegue postar nova
  // resposta (o tópico continua visível, só fecha pra novas respostas)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  replies ForumReply[]

  @@index([authorId])
  @@index([createdAt])
  @@map("forum_threads")
}

model ForumReply {
  id        String      @id @default(uuid())
  threadId  String      @map("thread_id")
  thread    ForumThread @relation(fields: [threadId], references: [id])
  authorId  String      @map("author_id")
  author    User        @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([threadId])
  @@map("forum_replies")
}

// =============================================================
// DENÚNCIAS — moderação de conteúdo
// =============================================================

model Report {
  id         String           @id @default(uuid())
  reporterId String           @map("reporter_id")
  reporter   User             @relation("ReportsMade", fields: [reporterId], references: [id])
  targetType ReportTargetType @map("target_type")
  targetId   String           @map("target_id")
  reason     String
  status     ReportStatus     @default(PENDING)
  resolvedAt DateTime?        @map("resolved_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([status])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("reports")
}

// =============================================================
// SUPORTE — chamados abertos pelos membros
// =============================================================

model SupportTicket {
  id             String                 @id @default(uuid())
  userId         String                 @map("user_id")
  user           User                   @relation(fields: [userId], references: [id])
  category       SupportCategory        @default(OUTRO)
  message        String
  // Anexo opcional — foto ou vídeo do problema relatado
  attachmentKey  String?                @map("attachment_key")
  attachmentUrl  String?                @map("attachment_url")
  attachmentType SupportAttachmentType? @map("attachment_type")
  status         SupportTicketStatus    @default(PENDING)
  resolvedAt     DateTime?              @map("resolved_at")
  createdAt      DateTime               @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

// =============================================================
// ARTISTS
// =============================================================

model Artist {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  bio       String?
  photoKey  String?  @map("photo_key") // chave R2
  photoUrl  String?  @map("photo_url") // URL pública CDN
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Perfil de artista autogerenciado por um usuário (role ARTIST) que
  // faz upload das próprias músicas — nulo para artistas cadastrados
  // manualmente pelo admin
  userId String? @unique @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  tracks Track[]

  @@index([slug])
  @@index([active])
  @@map("artists")
}

// =============================================================
// TRACKS (músicas)
// =============================================================

model Track {
  id          String  @id @default(uuid())
  slug        String  @unique
  title       String
  description String?
  genre       String?
  bpm         Int?
  key         String? // tom musical

  // Artistas
  artistId     String  @map("artist_id")
  artist       Artist  @relation(fields: [artistId], references: [id])
  producerName String? @map("producer_name") // pode não ser usuário da plataforma

  // Usuário (role ARTIST) que enviou a faixa pelo upload da comunidade —
  // nulo para músicas cadastradas direto pelo admin
  submittedById String? @map("submitted_by_id")
  submittedBy   User?   @relation("TrackSubmittedBy", fields: [submittedById], references: [id])

  // Storage R2
  audioKey       String  @map("audio_key") // chave R2 do arquivo de áudio
  audioFormat    String  @map("audio_format") // mp3 | wav | flac
  audioSizeBytes BigInt? @map("audio_size_bytes")
  coverKey       String? @map("cover_key") // chave R2 da capa
  coverUrl       String? @map("cover_url") // URL pública CDN

  // Cache da versão "música + vinheta" servida no download (gerada sob
  // demanda no primeiro download após publicar ou após trocar a vinheta
  // de download — fica salva pra não reprocessar em todo clique).
  // downloadAudioVinhetaKey guarda qual vinheta foi usada nessa versão,
  // pra saber quando precisa regenerar.
  downloadAudioKey        String? @map("download_audio_key")
  downloadAudioVinhetaKey String? @map("download_audio_vinheta_key")

  // Controle
  published     Boolean   @default(false)
  publishedAt   DateTime? @map("published_at")
  downloadCount Int       @default(0) @map("download_count")
  // Fixada pelo admin no feed (/musicas-recentes) — enquanto true, ignora
  // a janela de expiração (24/36/48h) e aparece sempre no topo
  pinned        Boolean   @default(false)
  pinnedAt      DateTime? @map("pinned_at")
  // Destaque comprado na loja (item FEATURE_TRACK) — diferente do `pinned`
  // do admin (permanente, sem expiração). Máx. 3 faixas com featuredUntil
  // no futuro simultaneamente; entre elas, a com mais tempo restante fica
  // no topo do feed.
  featuredUntil DateTime? @map("featured_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  downloads Download[]
  likes     TrackLike[]
  comments  TrackComment[]

  @@index([slug])
  @@index([artistId])
  @@index([published])
  @@index([genre])
  @@index([submittedById])
  @@index([pinned])
  @@map("tracks")
}

model TrackComment {
  id              String    @id @default(uuid())
  trackId         String    @map("track_id")
  track           Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  authorId        String    @map("author_id")
  author          User      @relation(fields: [authorId], references: [id])
  content         String
  // Preenchido quando o autor edita o comentário — usado para mostrar
  // "Comentário editado" com a data/hora abaixo do texto
  editedAt        DateTime? @map("edited_at")
  // Fixado pelo admin — enquanto true, ignora a janela de expiração e
  // aparece sempre no topo dos comentários da música
  pinned          Boolean   @default(false)
  pinnedAt        DateTime? @map("pinned_at")
  // Preenchido quando o fixo vem da loja (item PIN_TRACK_COMMENT, comprado
  // pelo próprio artista) — nulo = fixado pelo admin, sem expiração;
  // valor = expira 24h após o uso, sem reembolso de pontos
  pinnedExpiresAt DateTime? @map("pinned_expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([trackId])
  @@index([pinned])
  @@map("track_comments")
}

model TrackLike {
  id        String   @id @default(uuid())
  trackId   String   @map("track_id")
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([trackId, userId])
  @@index([trackId])
  @@index([userId])
  @@map("track_likes")
}

// =============================================================
// DOWNLOADS
// =============================================================

model Download {
  id      String @id @default(uuid())
  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  // Geolocalização processada (sem IP)
  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?

  // Device info processado
  device  String? // mobile | desktop | tablet
  browser String?
  os      String?

  // Controle
  status           DownloadStatus @default(INICIADO)
  signedUrlExpiry  DateTime?      @map("signed_url_expiry")
  downloadSuspeito Boolean        @default(false) @map("download_suspeito")
  createdAt        DateTime       @default(now()) @map("created_at")
  completedAt      DateTime?      @map("completed_at")

  @@index([trackId])
  @@index([downloadSuspeito])
  @@index([createdAt])
  @@index([status])
  // Índice composto para queries de analytics filtradas
  @@index([trackId, downloadSuspeito, createdAt])
  @@map("downloads")
}

// =============================================================
// ANALYTICS — camada 1 (dados técnicos, retenção 90 dias)
// =============================================================

model AnalyticsRawEvent {
  id        String    @id @default(uuid())
  eventType EventType @map("event_type")

  // IP anonimizado — NUNCA o IP original
  ipHash    String? @map("ip_hash") // SHA-256(IP + salt_do_periodo)
  hashKeyId String? @map("hash_key_id") // referência ao AnalyticsHashKey usado

  // Device / contexto técnico
  userAgent String? @map("user_agent")
  device    String?
  browser   String?
  os        String?
  referer   String?

  // Localização processada
  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?

  // Contexto do evento
  trackId   String? @map("track_id") // presente em eventos de música
  sessionId String? @map("session_id") // gerado no client, não vinculado a user
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")
  // TTL: deletar após 90 dias via job ou cron
  expiresAt DateTime @map("expires_at")

  @@index([eventType])
  @@index([expiresAt]) // índice para deleção por expiração
  @@index([ipHash])
  @@index([createdAt])
  @@map("analytics_raw_events")
}

// =============================================================
// ANALYTICS — camada 2 (dados processados, sem IP, permanentes)
// =============================================================

model AnalyticsEvent {
  id        String    @id @default(uuid())
  eventType EventType @map("event_type")

  // Localização agregada (país/cidade, nunca IP)
  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?

  // Device info
  device  String?
  browser String?
  os      String?

  // Contexto
  trackId   String? @map("track_id")
  sessionId String? @map("session_id")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([trackId])
  @@index([createdAt])
  @@index([country])
  // Índice composto: base de todos os dashboards
  @@index([eventType, createdAt])
  @@map("analytics_events")
}

// =============================================================
// ANALYTICS — chaves de hash rotativas (LGPD)
// =============================================================

model AnalyticsHashKey {
  id            String   @id @default(uuid())
  // salt armazenado criptografado — nunca em texto puro
  saltEncrypted String   @map("salt_encrypted")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([active])
  @@index([periodEnd])
  @@map("analytics_hash_keys")
}

// =============================================================
// ADMIN SESSIONS
// =============================================================

model AdminSession {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  // Tokens nunca armazenados — apenas hash SHA-256
  accessTokenHash  String @unique @map("access_token_hash")
  refreshTokenHash String @unique @map("refresh_token_hash")

  // Contexto da sessão
  ipHash    String? @map("ip_hash")
  userAgent String? @map("user_agent")
  device    String?

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([accessTokenHash])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("admin_sessions")
}

// =============================================================
// AUDIT LOGS — rastreabilidade de ações admin
// =============================================================

model AuditLog {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  user       User        @relation(fields: [userId], references: [id])
  action     AuditAction
  entityId   String?     @map("entity_id") // ID da entidade afetada
  entityType String?     @map("entity_type") // "track" | "artist" etc
  metadata   Json? // diff antes/depois, contexto extra
  ipHash     String?     @map("ip_hash")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// WAITLIST
// =============================================================

model Waitlist {
  id               String              @id @default(uuid())
  email            String              @unique
  name             String?
  phone            String?
  tipoUsuario      WaitlistTipoUsuario @map("tipo_usuario")
  message          String? // campo livre opcional
  consentedAt      DateTime            @map("consented_at") // LGPD: momento do aceite
  invitedAt        DateTime?           @map("invited_at") // preenchido quando convite for aceito
  // Chave aleatória gerada ao aceitar o convite — usada no link de cadastro
  inviteCode       String?             @unique @map("invite_code")
  // Momento em que o convite foi consumido (cadastro concluído) — single-use
  usedAt           DateTime?           @map("used_at")
  // Preenchido quando essa entrada veio de uma indicação (usuário comprou
  // "Convite prioritário" na loja e indicou esse email) — mostrado no
  // /admin/convites junto com o email de quem indicou, pra detectar abuso
  // (muitos pedidos do mesmo indicador = sinal de fraude)
  referredByUserId String?             @map("referred_by_user_id")
  referredByUser   User?               @relation("WaitlistReferrals", fields: [referredByUserId], references: [id])
  // true = reordena no topo da fila do admin; NUNCA pula o aceite manual
  priority         Boolean             @default(false)
  createdAt        DateTime            @default(now()) @map("created_at")

  @@index([tipoUsuario])
  @@index([invitedAt])
  @@index([referredByUserId])
  @@index([priority])
  @@map("waitlist")
}

// =============================================================
// CONSENT EVENTS — rastreabilidade LGPD
// =============================================================

model ConsentEvent {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id") // ID anônimo de sessão
  eventType   String   @map("event_type") // "CONSENT_GIVEN" | "CONSENT_REVOKED"
  consentType String   @map("consent_type") // "analytics" | "all"
  ipHash      String?  @map("ip_hash")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("consent_events")
}

// =============================================================
// APP SETTINGS — configurações globais (linha única "singleton")
// =============================================================

// =============================================================
// GAMIFICAÇÃO — pontos, loja, mercado de preço dinâmico, promoções
// =============================================================

// Ledger completo de toda movimentação de XP — nunca alterar User.totalXp
// direto, sempre passar por aqui (PointsService). points pode ser negativo
// (resgate de loja, penalidade de abuso).
model PointsHistory {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id])
  action      PointActionType
  points      Int
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")

  // (userId, createdAt) cobre tanto o total acumulado quanto o ranking
  // semanal (soma filtrada pela janela, sem precisar zerar nada)
  @@index([userId, createdAt])
  @@index([action])
  @@map("points_history")
}

// Catálogo da loja — preço é o único campo que o mercado de oferta/demanda
// reajusta (StorePriceAdjustment guarda o histórico). Os limites de
// venda/concorrência ficam aqui pra não virar regra hardcoded no código.
model StoreItem {
  id       String        @id @default(uuid())
  key      StoreItemKey  @unique
  label    String
  audience StoreAudience
  price    Int

  // Máximo de unidades desse item simultaneamente "ativas" na plataforma
  // (ex: 3 faixas em destaque ao mesmo tempo) — null = sem limite de slot
  maxConcurrent       Int? @map("max_concurrent")
  // Janela e teto de vendas pra throttle de slot (ex: 3 vendas por 36h)
  saleWindowHours     Int? @map("sale_window_hours")
  saleWindowLimit     Int? @map("sale_window_limit")
  // Duração do efeito após o uso, em horas (ex: 24h de destaque/fixação;
  // null = não aplicável, ex. convite e armazenamento são efeito imediato)
  durationHours       Int? @map("duration_hours")
  // Teto de quantas vezes UM usuário pode comprar este item (ex: 5x no
  // armazenamento = +1GB no total); null = sem teto por usuário
  maxPurchasesPerUser Int? @map("max_purchases_per_user")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchases        StorePurchase[]
  thresholdEvents  StoreThresholdEvent[]
  priceAdjustments StorePriceAdjustment[]

  @@map("store_items")
}

// Uma compra concreta — targetType/targetId aponta pro que foi
// destacado/fixado (faixa, comentário de música, post do feed) quando o
// item exige escolher um alvo; fica nulo pros itens de efeito imediato
// (convite, armazenamento, mapeamento, premium).
model StorePurchase {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  user        User                @relation(fields: [userId], references: [id])
  storeItemId String              @map("store_item_id")
  storeItem   StoreItem           @relation(fields: [storeItemId], references: [id])
  pricePaid   Int                 @map("price_paid")
  status      StorePurchaseStatus @default(AWAITING_USE)

  targetType String? @map("target_type") // "TRACK" | "TRACK_COMMENT" | "POST"
  targetId   String? @map("target_id")

  // Presente do admin — pula a cobrança de pontos (pricePaid = 0)
  isGift          Boolean @default(false) @map("is_gift")
  giftedByAdminId String? @map("gifted_by_admin_id")

  purchasedAt DateTime  @default(now()) @map("purchased_at")
  // Prazo pra efetivamente usar o item (ex: 24h) — passou e não usou,
  // perde sem reembolso (status vira EXPIRED)
  usableUntil DateTime? @map("usable_until")
  usedAt      DateTime? @map("used_at")
  // Quando o efeito (destaque/fixação) deixa de valer — calculado a partir
  // de usedAt + durationHours do StoreItem
  expiresAt   DateTime? @map("expires_at")

  @@index([userId])
  @@index([storeItemId, purchasedAt])
  @@index([status])
  @@map("store_purchases")
}

// Marco histórico: usuário cruzou o preço do item mais caro de uma loje
// pela primeira vez NESSE valor de preço. É permanente — gastar os pontos
// depois não desfaz o marco. Alimenta o contador que dispara reajuste.
model StoreThresholdEvent {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  storeItemId  String    @map("store_item_id")
  storeItem    StoreItem @relation(fields: [storeItemId], references: [id])
  priceAtReach Int       @map("price_at_reach")
  reachedAt    DateTime  @default(now()) @map("reached_at")

  @@unique([userId, storeItemId, priceAtReach])
  @@index([storeItemId, reachedAt])
  @@map("store_threshold_events")
}

// Auditoria de cada reajuste de preço — pra acompanhar a "inflação" da
// loja ao longo do tempo no painel admin.
model StorePriceAdjustment {
  id               String    @id @default(uuid())
  storeItemId      String    @map("store_item_id")
  storeItem        StoreItem @relation(fields: [storeItemId], references: [id])
  oldPrice         Int       @map("old_price")
  newPrice         Int       @map("new_price")
  triggeredByCount Int       @map("triggered_by_count")
  windowStart      DateTime  @map("window_start")
  windowEnd        DateTime  @map("window_end")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([storeItemId, createdAt])
  @@map("store_price_adjustments")
}

// Multiplicador de XP configurável pelo admin — data específica ou dia da
// semana recorrente (ex: toda terça, dia de menor acesso)
model PointsPromotion {
  id         String    @id @default(uuid())
  label      String
  multiplier Float     @default(2.0)
  startAt    DateTime? @map("start_at")
  endAt      DateTime? @map("end_at")
  // 0=domingo .. 6=sábado — recorrente, ignora startAt/endAt quando setado
  weekday    Int?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("points_promotions")
}

model AppSettings {
  id                  String  @id @default("singleton")
  // Aceite automático de convites (piloto automático com limite)
  autoAcceptEnabled   Boolean @default(false) @map("auto_accept_enabled")
  autoAcceptRemaining Int     @default(0) @map("auto_accept_remaining")

  // Limites de upload de áudio por tipo de conteúdo (em MB)
  musicMaxSizeMb   Int     @default(10) @map("music_max_size_mb")
  podcastMaxSizeMb Int     @default(100) @map("podcast_max_size_mb")
  // Upload de podcast existe como modelo de configuração, mas a função
  // ainda não foi liberada para os artistas — desligado por padrão.
  podcastEnabled   Boolean @default(false) @map("podcast_enabled")

  // Janela de exibição pública de músicas e comentários (em horas) — depois
  // desse prazo, somem do catálogo/feed mas continuam no banco (soft-hide).
  contentExpirationHours Int @default(24) @map("content_expiration_hours")

  // Vinheta tocada dinamicamente pelo player ao fim de cada faixa (opção 2
  // do plano: arquivo separado, nunca concatenado no áudio original). Nulo
  // = nenhuma vinheta configurada, player só toca a faixa normalmente.
  vinhetaKey String? @map("vinheta_key")

  // Vinheta colada fisicamente (ffmpeg) no final do arquivo entregue no
  // download — separada da vinheta do player porque, depois de baixado,
  // não existe mais player controlando nada. Nulo = download sai sem vinheta.
  vinhetaDownloadKey String? @map("vinheta_download_key")

  // Punição por abuso de indicação de convite (nível 2 da escala) — dias
  // de bloqueio da função de convidar. Editável pelo admin, sem valor fixo
  // no código, porque o critério pode mudar com a experiência real.
  // Nível 1 (cancela só os pontos da indicação) e nível 3 (suspende a
  // conta, via User.blocked) não precisam de duração configurável.
  inviteAbuseBlockDays Int @default(30) @map("invite_abuse_block_days")

  // Mercado de preço dinâmico da loja — quantas pessoas precisam cruzar o
  // preço do item mais caro de uma loja, dentro da janela, pra disparar
  // reajuste em todos os itens dessa loja (ver StoreThresholdEvent)
  storeDynamicPriceThresholdCount  Int @default(3) @map("store_dynamic_price_threshold_count")
  storeDynamicPriceWindowHours     Int @default(720) @map("store_dynamic_price_window_hours") // 30 dias
  storeDynamicPriceIncreasePercent Int @default(20) @map("store_dynamic_price_increase_percent")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
