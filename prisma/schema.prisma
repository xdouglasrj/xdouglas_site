// =============================================================
// xDouglas — Schema Prisma Fase 1
// =============================================================
// Tabelas ativas na Fase 1:
//   users, artists, tracks, downloads
//   analytics_raw_events, analytics_events, analytics_hash_keys
//   admin_sessions, audit_logs
//   waitlist, consent_events
//
// Reservadas para Fase 2+ (não criadas agora):
//   memberships, plans, feature_permissions, invites
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum Role {
  GUEST
  MEMBER
  ARTIST
  ARTIST_SUPPORTER
  ADMIN
}

enum DownloadStatus {
  INICIADO
  CONCLUIDO
  EXPIRADO
}

enum WaitlistTipoUsuario {
  DJ
  PRODUTOR
  ARTISTA
  MUSICO
  OUVINTE
  OUTRO
}

enum AuditAction {
  LOGIN
  LOGOUT
  TRACK_CREATE
  TRACK_UPDATE
  TRACK_DELETE
  ARTIST_CREATE
  ARTIST_UPDATE
  ARTIST_DELETE
  ADMIN_ACCESS
  SUSPICIOUS_DOWNLOAD_FLAGGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}

enum EventType {
  PAGE_VIEW
  MUSIC_VIEW
  DOWNLOAD_START
  DOWNLOAD_COMPLETE
  DOWNLOAD_FAILED
  WAITLIST_JOIN
  CONSENT_GIVEN
  CONSENT_REVOKED
}

// =============================================================
// USERS — base de todos os papéis (Fase 1 usa apenas ADMIN)
// =============================================================

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  username   String?  @unique @map("username")
  password   String   // bcrypt hash
  name       String?
  role       Role     @default(GUEST)
  active     Boolean  @default(true)
  // Código de convite informado no cadastro de músico/produtor — validado manualmente por agora
  inviteCode String?  @map("invite_code")
  phone      String?
  // Nome artístico — preenchido no cadastro para quem não é Ouvinte
  artisticName String? @map("artistic_name")
  newsletterOptIn Boolean @default(false) @map("newsletter_opt_in")
  lastLoginAt DateTime? @map("last_login_at")
  // Bloqueado pelo admin — impede novo cadastro com mesmo email/usuário/whatsapp
  blocked    Boolean  @default(false)
  blockedAt  DateTime? @map("blocked_at")
  // Foto de perfil — chave R2 + URL pública CDN
  photoKey   String?  @map("photo_key")
  photoUrl   String?  @map("photo_url")
  // Redefinição de senha — apenas o hash do token é armazenado, nunca o token original
  resetPasswordTokenHash  String?   @unique @map("reset_password_token_hash")
  resetPasswordExpiresAt  DateTime? @map("reset_password_expires_at")
  // Marca quando o token foi efetivamente usado para trocar a senha —
  // permite distinguir "link já usado" de "link inválido/expirado"
  resetPasswordUsedAt     DateTime? @map("reset_password_used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  adminSessions AdminSession[]
  auditLogs     AuditLog[]
  artist        Artist?
  submittedTracks Track[] @relation("TrackSubmittedBy")

  @@index([email])
  @@index([role])
  @@map("users")
}

// =============================================================
// ARTISTS
// =============================================================

model Artist {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  bio         String?
  photoKey    String?  @map("photo_key")   // chave R2
  photoUrl    String?  @map("photo_url")   // URL pública CDN
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Perfil de artista autogerenciado por um usuário (role ARTIST) que
  // faz upload das próprias músicas — nulo para artistas cadastrados
  // manualmente pelo admin
  userId      String?  @unique @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])

  tracks Track[]

  @@index([slug])
  @@index([active])
  @@map("artists")
}

// =============================================================
// TRACKS (músicas)
// =============================================================

model Track {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  genre       String?
  bpm         Int?
  key         String?  // tom musical

  // Artistas
  artistId    String   @map("artist_id")
  artist      Artist   @relation(fields: [artistId], references: [id])
  producerName String? @map("producer_name") // pode não ser usuário da plataforma

  // Usuário (role ARTIST) que enviou a faixa pelo upload da comunidade —
  // nulo para músicas cadastradas direto pelo admin
  submittedById String? @map("submitted_by_id")
  submittedBy   User?   @relation("TrackSubmittedBy", fields: [submittedById], references: [id])

  // Storage R2
  audioKey      String  @map("audio_key")      // chave R2 do arquivo de áudio
  audioFormat   String  @map("audio_format")   // mp3 | wav | flac
  audioSizeBytes BigInt? @map("audio_size_bytes")
  coverKey      String? @map("cover_key")      // chave R2 da capa
  coverUrl      String? @map("cover_url")      // URL pública CDN

  // Controle
  published     Boolean  @default(false)
  publishedAt   DateTime? @map("published_at")
  downloadCount Int      @default(0) @map("download_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  downloads Download[]

  @@index([slug])
  @@index([artistId])
  @@index([published])
  @@index([genre])
  @@index([submittedById])
  @@map("tracks")
}

// =============================================================
// DOWNLOADS
// =============================================================

model Download {
  id              String         @id @default(uuid())
  trackId         String         @map("track_id")
  track           Track          @relation(fields: [trackId], references: [id])

  // Geolocalização processada (sem IP)
  country         String?
  region          String?
  city            String?
  latitude        Float?
  longitude       Float?

  // Device info processado
  device          String?        // mobile | desktop | tablet
  browser         String?
  os              String?

  // Controle
  status          DownloadStatus @default(INICIADO)
  signedUrlExpiry DateTime?      @map("signed_url_expiry")
  downloadSuspeito Boolean       @default(false) @map("download_suspeito")
  createdAt       DateTime       @default(now()) @map("created_at")
  completedAt     DateTime?      @map("completed_at")

  @@index([trackId])
  @@index([downloadSuspeito])
  @@index([createdAt])
  @@index([status])
  // Índice composto para queries de analytics filtradas
  @@index([trackId, downloadSuspeito, createdAt])
  @@map("downloads")
}

// =============================================================
// ANALYTICS — camada 1 (dados técnicos, retenção 90 dias)
// =============================================================

model AnalyticsRawEvent {
  id        String    @id @default(uuid())
  eventType EventType @map("event_type")

  // IP anonimizado — NUNCA o IP original
  ipHash    String?   @map("ip_hash")    // SHA-256(IP + salt_do_periodo)
  hashKeyId String?   @map("hash_key_id") // referência ao AnalyticsHashKey usado

  // Device / contexto técnico
  userAgent String?   @map("user_agent")
  device    String?
  browser   String?
  os        String?
  referer   String?

  // Localização processada
  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?

  // Contexto do evento
  trackId   String?   @map("track_id")  // presente em eventos de música
  sessionId String?   @map("session_id") // gerado no client, não vinculado a user
  metadata  Json?

  createdAt DateTime  @default(now()) @map("created_at")
  // TTL: deletar após 90 dias via job ou cron
  expiresAt DateTime  @map("expires_at")

  @@index([eventType])
  @@index([expiresAt])  // índice para deleção por expiração
  @@index([ipHash])
  @@index([createdAt])
  @@map("analytics_raw_events")
}

// =============================================================
// ANALYTICS — camada 2 (dados processados, sem IP, permanentes)
// =============================================================

model AnalyticsEvent {
  id        String    @id @default(uuid())
  eventType EventType @map("event_type")

  // Localização agregada (país/cidade, nunca IP)
  country   String?
  region    String?
  city      String?

  // Device info
  device    String?
  browser   String?
  os        String?

  // Contexto
  trackId   String?   @map("track_id")
  sessionId String?   @map("session_id")
  metadata  Json?

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([eventType])
  @@index([trackId])
  @@index([createdAt])
  @@index([country])
  // Índice composto: base de todos os dashboards
  @@index([eventType, createdAt])
  @@map("analytics_events")
}

// =============================================================
// ANALYTICS — chaves de hash rotativas (LGPD)
// =============================================================

model AnalyticsHashKey {
  id          String   @id @default(uuid())
  // salt armazenado criptografado — nunca em texto puro
  saltEncrypted String @map("salt_encrypted")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([active])
  @@index([periodEnd])
  @@map("analytics_hash_keys")
}

// =============================================================
// ADMIN SESSIONS
// =============================================================

model AdminSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id])

  // Tokens nunca armazenados — apenas hash SHA-256
  accessTokenHash  String   @unique @map("access_token_hash")
  refreshTokenHash String   @unique @map("refresh_token_hash")

  // Contexto da sessão
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  device    String?

  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([accessTokenHash])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("admin_sessions")
}

// =============================================================
// AUDIT LOGS — rastreabilidade de ações admin
// =============================================================

model AuditLog {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id])
  action    AuditAction
  entityId  String?     @map("entity_id")   // ID da entidade afetada
  entityType String?    @map("entity_type") // "track" | "artist" etc
  metadata  Json?       // diff antes/depois, contexto extra
  ipHash    String?     @map("ip_hash")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// WAITLIST
// =============================================================

model Waitlist {
  id            String              @id @default(uuid())
  email         String              @unique
  name          String?
  phone         String?
  tipoUsuario   WaitlistTipoUsuario @map("tipo_usuario")
  message       String?             // campo livre opcional
  consentedAt   DateTime            @map("consented_at") // LGPD: momento do aceite
  invitedAt     DateTime?           @map("invited_at")   // preenchido quando convite for aceito
  // Chave aleatória gerada ao aceitar o convite — usada no link de cadastro
  inviteCode    String?             @unique @map("invite_code")
  // Momento em que o convite foi consumido (cadastro concluído) — single-use
  usedAt        DateTime?           @map("used_at")
  createdAt     DateTime            @default(now()) @map("created_at")

  @@index([tipoUsuario])
  @@index([invitedAt])
  @@map("waitlist")
}

// =============================================================
// CONSENT EVENTS — rastreabilidade LGPD
// =============================================================

model ConsentEvent {
  id          String    @id @default(uuid())
  sessionId   String    @map("session_id")  // ID anônimo de sessão
  eventType   String    @map("event_type")  // "CONSENT_GIVEN" | "CONSENT_REVOKED"
  consentType String    @map("consent_type") // "analytics" | "all"
  ipHash      String?   @map("ip_hash")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("consent_events")
}

// =============================================================
// APP SETTINGS — configurações globais (linha única "singleton")
// =============================================================

model AppSettings {
  id                  String   @id @default("singleton")
  // Aceite automático de convites (piloto automático com limite)
  autoAcceptEnabled   Boolean  @default(false) @map("auto_accept_enabled")
  autoAcceptRemaining Int      @default(0) @map("auto_accept_remaining")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
