# =============================================================
# xDouglas — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# NUNCA commite .env.local no repositório
# =============================================================

# -------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# -------------------------------------------------------------
# Para desenvolvimento local com Docker:
DATABASE_URL="postgresql://xdouglas:xdouglas_dev_password@localhost:5432/xdouglas?schema=public"

# DIRECT_URL: necessário para Prisma Migrate (sem connection pooler)
# Em produção com Supabase/Neon, usar a URL direta (não pooled)
DIRECT_URL="postgresql://xdouglas:xdouglas_dev_password@localhost:5432/xdouglas?schema=public"

# -------------------------------------------------------------
# AUTENTICAÇÃO JWT
# -------------------------------------------------------------
# Gere com: openssl rand -hex 32
JWT_SECRET="TROQUE_POR_STRING_ALEATORIA_DE_64_CHARS"

# Gere com: openssl rand -hex 32
REFRESH_TOKEN_SECRET="TROQUE_POR_OUTRA_STRING_ALEATORIA_64_CHARS"

# -------------------------------------------------------------
# ANALYTICS — LGPD
# -------------------------------------------------------------
# Chave para criptografar os salts dos hashes de IP (AES-256)
# Gere com: openssl rand -hex 32
ANALYTICS_ENCRYPTION_KEY="TROQUE_POR_STRING_HEX_DE_64_CHARS"

# -------------------------------------------------------------
# CLOUDFLARE R2 STORAGE
# -------------------------------------------------------------
R2_ACCOUNT_ID="seu_account_id_cloudflare"
R2_ACCESS_KEY_ID="sua_access_key_id"
R2_SECRET_ACCESS_KEY="sua_secret_access_key"
R2_BUCKET_NAME="xdouglas-audio"

# Hostname público do R2 (para imagens via next/image)
# Ex: pub-xxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_HOSTNAME="pub-placeholder.r2.dev"

# URL base pública para capas (bucket com acesso público)
# Ex: https://pub-xxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL="https://pub-placeholder.r2.dev"

# -------------------------------------------------------------
# GEOLOCALIZAÇÃO
# -------------------------------------------------------------
# ip-api.com não requer chave para uso básico (45 req/min)
# Para produção com mais volume, considere plano pago
IP_API_URL="http://ip-api.com/json"

# -------------------------------------------------------------
# APLICAÇÃO
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# -------------------------------------------------------------
# MANUTENÇÃO (cron jobs)
# -------------------------------------------------------------
# Segredo para proteger o endpoint /api/analytics/cleanup
# Gere com: openssl rand -hex 32
# Configurar no Vercel Cron ou serviço externo como Authorization: Bearer <valor>
CRON_SECRET="TROQUE_POR_STRING_ALEATORIA"
